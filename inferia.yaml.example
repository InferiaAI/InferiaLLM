# inferia.yaml — InferiaLLM unified configuration
#
# SPLIT RULE: yaml owns application behavior only.
# Hosting (host, port, workers, reload), networking (proxy_headers,
# forwarded_allow_ips), URLs (api_gateway_url, service_urls, dashboard,
# database/redis URLs), SSL settings, and connection credentials live in
# env vars and are NOT configured here.
#
# Discovery:
#   1. inferiallm start --config /path/to/inferia.yaml
#   2. INFERIA_CONFIG env var
#   3. ./inferia.yaml in CWD
#   4. /etc/inferia/inferia.yaml
#
# Secrets MUST come from env via ${VAR} interpolation. Plain secrets in this
# file are rejected by the schema validator.
#
# Precedence (highest → lowest): CLI args > env > .env > this file > defaults
version: 1

environment: development
log_level: INFO

# ─── Shared security ────────────────────────────────────────────────────
# Secrets MUST come from env. Defaults shown here are non-secret strings
# long enough to pass schema validation in dev; the schema rejects known
# placeholder strings, so swap these for `${VAR}` in production.
security:
  jwt_secret_key: ${JWT_SECRET_KEY:-dev-jwt-secret-thirty-two-bytes-min}
  jwt_algorithm: HS256
  internal_api_key: ${INTERNAL_API_KEY:-dev-internal-api-key-thirty-two-bytes}
  secret_encryption_key: ${SECRET_ENCRYPTION_KEY:-}
  log_encryption_key: ${LOG_ENCRYPTION_KEY:-}
  allowed_origins:
    - http://localhost:3000
    - http://localhost:5173
    - http://localhost:8001

# ─── Per-service ────────────────────────────────────────────────────────
services:
  api_gateway:
    enabled: true
    default_org_name: "Default Organization"
    auth:
      provider: local
    superadmin:
      email: ${SUPERADMIN_EMAIL:-}
      password: ${SUPERADMIN_PASSWORD:-}
    rate_limit:
      enabled: false
      requests_per_minute: 10000
      burst_size: 1000
      use_redis: false
    http_client:
      service_timeout_seconds: 10.0
      service_connect_timeout_seconds: 3.0
      service_max_connections: 500
      service_max_keepalive: 100
      proxy_timeout_seconds: 300.0
      proxy_max_connections: 500
      proxy_max_keepalive: 100

  inference:
    enabled: true
    request_timeout: 30
    verify_ssl: true
    upstream:
      http_timeout_seconds: 60.0
      http_connect_timeout_seconds: 10.0
      video_timeout_seconds: 300.0
      http_max_connections: 500
      http_max_keepalive_connections: 100
      global_max_in_flight: 0
      per_deployment_max_in_flight: 100
      slot_acquire_timeout_seconds: 20.0
      allowed_internal_hosts: ""
      max_response_bytes: 52428800
    gateway_client:
      http_max_connections: 1000
      http_max_keepalive_connections: 100
    context_cache:
      ttl: 30
      maxsize: 1000
    quota_cache:
      ttl_seconds: 1.0
      maxsize: 10000

  guardrail:
    enabled: true
    default_guardrail_engine: llm-guard
    llama_guard_model_id: meta-llama/llama-guard-4-12b
    banned_substrings: ""
    controls:
      enable_guardrails: true
      enable_toxicity: false
      enable_prompt_injection: false
      enable_secrets: false
      enable_code_scanning: false
      enable_sensitive_info: false
      enable_no_refusal: false
      enable_bias: false
      enable_relevance: false
    thresholds:
      toxicity_threshold: 0.7
      prompt_injection_threshold: 0.8
      bias_threshold: 0.75
      relevance_threshold: 0.5
    pii:
      detection_enabled: true
      anonymize: true
      entity_types: []
      max_scan_time_seconds: 5.0

  data:
    enabled: true
    max_ingest_documents: 500
    max_document_size_bytes: 1000000

  orchestration:
    enabled: true
    readiness:
      default_readiness_timeout: 300
      default_polling_interval: 20
      ephemeral_failure_threshold_minutes: 10
    deployment_logs:
      deployment_log_buffer_size: 10000
      deployment_log_flush_interval: 10

# ─── Providers ──────────────────────────────────────────────────────────
# Compute providers (aws, gcp, azure, ibm, nosana) are NOT configured here.
# Manage them via the dashboard (`/dashboard/providers`) or the CLI:
#   inferiallm providers list
#   inferiallm providers add nosana --name prod --type api_key --value KEY
#   inferiallm providers update aws --name default --type access_key_id --value AKIA...
#   inferiallm providers remove nosana --name old_key
# All writes go to the database; the dashboard reflects them immediately.
