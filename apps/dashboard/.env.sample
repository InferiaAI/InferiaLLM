# Dashboard build-time configuration.
# Copy to .env.local for development; Vite inlines VITE_* vars at build time.

# Auth provider selector.
#   local    — show the email/password form and POST to /auth/login (default).
#   external — show the "Sign in with Inferia" button. The gateway runs the
#              full OAuth Authorization Code + PKCE flow against inferia-auth
#              and redirects back with the access token in the URL fragment.
#
# Must match the api_gateway's AUTH_PROVIDER setting in production.
VITE_AUTH_PROVIDER=local

# Public-facing URL of the inferia-auth instance, e.g. https://auth.inferia.local.
# Only used when VITE_AUTH_PROVIDER=external for the post-logout redirect to
# the IdP's /logout endpoint so the SSO cookie clears too. Leave blank in
# local mode.
VITE_EXTERNAL_AUTH_URL=
