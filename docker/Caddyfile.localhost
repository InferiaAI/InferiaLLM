# Plain-HTTP localhost front for InferiaLLM. The unified app serves the whole
# web surface (/api gateway, /inf inference, /v2 OCI mirror, / dashboard SPA) on
# a single origin, so this is a thin single-upstream proxy — no per-prefix split,
# no local file_server. http://localhost:8081 → the one app port.
{
	admin off
	auto_https off
}

:8081 {
	encode gzip

	# Forward everything to the unified app (APP_PORT, default 8000). It serves
	# the API surfaces AND the dashboard SPA itself; WebSocket upgrades pass
	# through automatically.
	reverse_proxy localhost:{$APP_PORT:8000}
}
