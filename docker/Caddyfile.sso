{
	# Caddy global options. `local_certs` forces Caddy's internal CA so the two
	# `tls internal` sites below get self-signed certificates from a CA Caddy
	# generated and parked in its data volume. No outbound ACME calls.
	local_certs
	auto_https disable_redirects
}

# -----------------------------------------------------------------------------
# inferia.local — the InferiaLLM unified web app.
# -----------------------------------------------------------------------------
# The unified container serves the ENTIRE web surface from one port (APP_PORT,
# default 8000): /api/* (gateway), /inf/* (inference), /v2/* (OCI mirror) and
# / (dashboard SPA). Caddy forwards everything to that single upstream — no
# per-prefix split. WebSocket upgrades (/api/v1/workers/channel, shell/logs)
# pass through automatically.
inferia.local {
	tls internal
	reverse_proxy inferia-app:{$APP_PORT:8000}
}

# -----------------------------------------------------------------------------
# auth.inferia.local — the inferia-auth IdP (OAuth2 endpoints + login UI).
# -----------------------------------------------------------------------------
auth.inferia.local {
	tls internal
	reverse_proxy inferia-auth:3000
}
