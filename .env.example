# --- Application Core ---
ENVIRONMENT="production"
LOG_LEVEL="INFO"

# --- Secrets ---
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD=
AUTH_PROVIDER="local"
EXTERNAL_AUTH_URL="http://inferia-auth:3000"
JWT_SECRET_KEY=
INTERNAL_API_KEY=
SECRET_ENCRYPTION_KEY=
LOG_ENCRYPTION_KEY=
ENABLE_2FA=false
INFERIA_SSH_AUTHORIZED_KEYS_FILE="./.ssh/authorized_keys"

# --- Single-port web ---
APP_PORT=8000
FORWARDED_ALLOW_IPS=""
ALLOWED_ORIGINS="http://localhost:3001,https://inferiallm.example.com"
DASHBOARD_API_GATEWAY_URL="https://inferiallm.example.com/api"
DASHBOARD_INFERENCE_URL="https://inferiallm.example.com/inf"
DASHBOARD_WEB_SOCKET_URL=""
DASHBOARD_SIDECAR_URL=""
INFERIA_CONTROL_PLANE_EXTERNAL_URL="https://inferiallm.example.com/api"
INFERIA_MODEL_MIRROR_BASE="https://inferiallm.example.com/api"

# --- Context / timeouts ---
CONTEXT_CACHE_TTL=60
CONTEXT_CACHE_MAXSIZE=1000
UPSTREAM_HTTP_TIMEOUT_SECONDS=600
UPSTREAM_HTTP_CONNECT_TIMEOUT_SECONDS=20

# --- Worker/AWS ---
INFERIA_WORKER_IMAGE=ghcr.io/inferiaai/inferia-worker
INFERIA_WORKER_IMAGE_TAG=0.2.9
INFERIA_BAKE_SSM_INSTANCE_PROFILE=inferia-engine-ami-builder

# --- Postgres ---
POSTGRES_USER=inferia
POSTGRES_PASSWORD=
DATABASE_URL="postgresql://inferia:CHANGEME@postgres:5432/inferia"
DATABASE_SSL=false
PG_ADMIN_USER=inferia
PG_ADMIN_PASSWORD=
INFERIA_DB=inferia

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB="0"
REDIS_USERNAME="default"
REDIS_PASSWORD=
REDIS_SSL=false

# --- Elasticsearch/Logstash ---
LOGSTASH_HOST=
LOGSTASH_PORT=5959
ELASTICSEARCH_URL=
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# --- Model cache ---
INFERIA_MODEL_CACHE_DIR=
INFERIA_MODEL_CACHE_MAX_GB=100
