# --- Application Core ---
ENVIRONMENT="production"
LOG_LEVEL="INFO"

# --- Secrets ---
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD=
# --- External SSO / auth ---
# AUTH_PROVIDER selects the auth mode: "local" (built-in users, default) |
# "inferiaauth" (InferiaAuth IdP) | "oidc" (generic OIDC). The EXTERNAL_* /
# OAUTH_* / OIDC_* vars below are consulted only in the SSO modes; on "local"
# they are dormant. Values here match the application defaults.
# EXTERNAL_AUTH_URL: base URL of the external IdP. EXTERNAL_AUTH_ISSUER: expected
# 'iss' (defaults to EXTERNAL_AUTH_URL). OAUTH_REDIRECT_URI: <public-url>/auth/callback.
# CATALOG_ADMIN_TOKEN: bearer token to declare the catalog at boot. EXTERNAL_SERVICE_ID:
# InferiaAuth service UUID (auto-resolved if empty). OIDC_ROLE_MAP: JSON {group:role},
# {} = authenticated->admin. SSL_CA_BUNDLE: custom CA path for a self-signed IdP.
AUTH_PROVIDER="local"
EXTERNAL_AUTH_URL="http://inferia-auth:3000"
EXTERNAL_AUTH_ISSUER=
APP_NAMESPACE="inferiallm"
OAUTH_CLIENT_ID=
OAUTH_REDIRECT_URI=
OAUTH_JWKS_CACHE_TTL_SECONDS=3600
CATALOG_ADMIN_TOKEN=
EXTERNAL_SERVICE_ID=
OIDC_GROUPS_CLAIM=groups
OIDC_ROLE_MAP={}
OIDC_DEFAULT_ROLE=viewer
VERIFY_SSL=true
SSL_CA_BUNDLE=
JWT_SECRET_KEY=
INTERNAL_API_KEY=
SECRET_ENCRYPTION_KEY=
LOG_ENCRYPTION_KEY=
ENABLE_2FA=false
INFERIA_SSH_AUTHORIZED_KEYS_FILE="./.ssh/authorized_keys"

# --- Single-port web ---
APP_PORT=8000
FORWARDED_ALLOW_IPS=""
ALLOWED_ORIGINS="http://localhost:3001,https://inferiallm.example.com"
DASHBOARD_API_GATEWAY_URL="https://inferiallm.example.com/api"
DASHBOARD_INFERENCE_URL="https://inferiallm.example.com/inf"
DASHBOARD_WEB_SOCKET_URL=""
DASHBOARD_SIDECAR_URL=""
INFERIA_CONTROL_PLANE_EXTERNAL_URL="https://inferiallm.example.com/api"
INFERIA_MODEL_MIRROR_BASE="https://inferiallm.example.com/api"

# --- Internal service ports (loopback) ---
# Override these when running on HOST networking to avoid colliding with other
# host services. The in-process clients derive their localhost target from the
# SAME var, so changing the port here moves both the listener and its callers.
# An explicit ORCHESTRATION_URL / ORCHESTRATION_GRPC_ADDR / NOSANA_SIDECAR_URL /
# AKASH_SIDECAR_URL still wins (split / remote deployments).
HTTP_PORT=8080
GRPC_PORT=50051
DEPIN_SIDECAR_PORT=3000

# --- Context / timeouts ---
CONTEXT_CACHE_TTL=60
CONTEXT_CACHE_MAXSIZE=1000
UPSTREAM_HTTP_TIMEOUT_SECONDS=600
UPSTREAM_HTTP_CONNECT_TIMEOUT_SECONDS=20

# --- Worker/AWS ---
INFERIA_WORKER_IMAGE=ghcr.io/inferiaai/inferia-worker
INFERIA_WORKER_IMAGE_TAG=0.2.9
INFERIA_BAKE_SSM_INSTANCE_PROFILE=inferia-engine-ami-builder

# --- Postgres ---
POSTGRES_USER=inferia
POSTGRES_PASSWORD=
DATABASE_URL="postgresql://inferia:CHANGEME@postgres:5432/inferia"
DATABASE_SSL=false
PG_ADMIN_USER=inferia
PG_ADMIN_PASSWORD=
INFERIA_DB=inferia

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB="0"
REDIS_USERNAME="default"
REDIS_PASSWORD=
REDIS_SSL=false

# --- Model cache ---
INFERIA_MODEL_CACHE_DIR=
INFERIA_MODEL_CACHE_MAX_GB=100
