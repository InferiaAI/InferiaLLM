# -----------------------------------------------------------------------------
# InferiaLLM Environment Configuration
# -----------------------------------------------------------------------------
# Configuration for Docker Deployment.
# Copy this file to .env and fill in your values.
# -----------------------------------------------------------------------------

# --- Application Core ---
ENVIRONMENT="production"
LOG_LEVEL="INFO"

# --- Security & Authentication ---
# CRITICAL: Change these in production!
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD="change-me-immediately"

# External auth provider (inferia-auth).
# Set AUTH_PROVIDER=external to delegate login/token-validation to inferia-auth.
# Superadmin login always works locally regardless of this setting.
AUTH_PROVIDER="local"
EXTERNAL_AUTH_URL="http://inferia-auth:3000"

# Used for signing JWT tokens. Generate with: openssl rand -hex 32
JWT_SECRET_KEY="replace-this-with-a-very-long-random-string"

# Used for internal service-to-service authentication (HTTP /internal/* endpoints
# and gRPC orchestration server). Must be the same value across all services.
# If unset, internal endpoints and gRPC will reject ALL requests (fail closed).
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY="replace-this-with-another-long-random-string"

# Used for encrypting sensitive fields in the database (32-byte base64-encoded key).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY="replace-with-32-byte-base64-encoded-key"

# Used for encrypting audit logs (32-byte hex key). Generate with: openssl rand -hex 32
LOG_ENCRYPTION_KEY="replace-with-32-byte-hex-key"

# --- Feature Flags ---
ENABLE_2FA=false

# --- SSH Access to Provisioned Workers ---
# Public-key file baked into every provisioned EC2 worker's authorized_keys
# (one public key per line). Mounted read-only into the orchestration container.
INFERIA_SSH_AUTHORIZED_KEYS_FILE="./.ssh/authorized_keys"

# --- Service Ports (host side) ---
DASHBOARD_PORT=3001
FILTRATION_GATEWAY_PORT=8000
INFERENCE_GATEWAY_PORT=8001

# --- Dashboard Runtime Config ---
# Public URLs injected into the dashboard at container startup (baked into
# /config.js by `inferiallm write-dashboard-config`). Leave blank to use the
# defaults (localhost:8000 / :8001).
# IMPORTANT: Use the DASHBOARD_ prefix to avoid colliding with backend
# service URL env vars (e.g. INFERENCE_URL is used by API Gateway config).
# Behind the reverse proxy (subdirectory routing) these point at the public
# hostname + path prefixes; everything is one origin so no CORS is needed.
# Replace inferiallm.example.com with your domain, or blank them for localhost.
# (subdomain layout instead? use https://api.example.com / https://inference.example.com.)
DASHBOARD_API_GATEWAY_URL="https://inferiallm.example.com/gw"
DASHBOARD_INFERENCE_URL="https://inferiallm.example.com/inf"
DASHBOARD_WEB_SOCKET_URL=""
DASHBOARD_SIDECAR_URL=""

# --- Reverse Proxy ---
# If behind a reverse proxy (nginx, Caddy, ALB), set this to the proxy IP(s)
# so uvicorn trusts X-Forwarded-For and resolves real client IPs for rate limiting.
# Comma-separated IPs/CIDRs, or "*" to trust all (not recommended in production).
# Leave blank when NOT behind a proxy. With the bundled nginx proxy the backend
# sees the proxy container's address, so set the compose network CIDR, e.g.:
#   FORWARDED_ALLOW_IPS="172.16.0.0/12"
FORWARDED_ALLOW_IPS=""

# Public control-plane URL that cloud workers (e.g. AWS EC2) dial back to.
# Behind the reverse proxy use the gateway prefix so the worker control channel
# reaches the API gateway through /gw. Must be reachable from the public internet.
INFERIA_CONTROL_PLANE_EXTERNAL_URL="https://inferiallm.example.com/gw"

# --- CORS ---
# Comma-separated list of allowed origins. Behind the reverse proxy include the
# public dashboard origin. With subdirectory routing the dashboard and APIs share
# that one origin (same-origin); this value still gates other clients (CLI,
# external apps) hitting the gateway.
ALLOWED_ORIGINS="http://localhost:3001,http://127.0.0.1:3001,http://0.0.0.0:3001,https://inferiallm.example.com"

# --- Context Cache Configuration ---
# TTL (seconds) and max size for the API key context cache in the Inference service.
CONTEXT_CACHE_TTL=60
CONTEXT_CACHE_MAXSIZE=1000

# --- Upstream HTTP Timeouts ---
# Large window for cold model load on memory-pressured hosts.
UPSTREAM_HTTP_TIMEOUT_SECONDS=600
UPSTREAM_HTTP_CONNECT_TIMEOUT_SECONDS=20

# --- Worker Image ---
# Tag of the inferia-worker image provisioned onto compute nodes.
INFERIA_WORKER_IMAGE_TAG=pullfix-1780256000

# --- Database ---
# Postgres service credentials (used by the postgres container)
POSTGRES_USER=inferia
POSTGRES_PASSWORD=inferia

# Application database connection URL
# cli_init derives PG_HOST, PG_PORT, INFERIA_DB_USER, INFERIA_DB_PASSWORD, INFERIA_DB from this.
DATABASE_URL="postgresql://inferia:inferia@postgres:5432/inferia"
DATABASE_SSL=false

# Admin credentials for initial DB bootstrap (inferiallm init)
PG_ADMIN_USER=inferia
PG_ADMIN_PASSWORD=inferia
INFERIA_DB=inferia

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB="0"
REDIS_USERNAME="default"
REDIS_PASSWORD=
REDIS_SSL=false

# --- Logstash (optional) ---
# Set LOGSTASH_HOST to the hostname of your Logstash container or server to
# enable structured log shipping. Leave blank to disable.
# When using the bundled Logstash container (docker compose --profile logstash up),
# set LOGSTASH_HOST=logstash.
LOGSTASH_HOST=
LOGSTASH_PORT=5959

# Elasticsearch output for the Logstash pipeline (optional)
ELASTICSEARCH_URL=
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# --- Solana / Nosana (DePIN Sidecar) ---
SOLANA_RPC_URL=""
NOSANA_PROD_KEY="replace-with-your-nosana-prod-key"

# --- Model Cache ---
# Local directory inside the app container where downloaded model files are
# stored. Backed by the `modelcache` named Docker volume; change only if you
# want to mount a different host path.
INFERIA_MODEL_CACHE_DIR=
# Maximum total size (GB) the model cache may occupy before LRU eviction kicks
# in. Default: 100 GB.
INFERIA_MODEL_CACHE_MAX_GB=100
# HuggingFace API token for downloading gated/private models. Leave blank for
# public models only.
INFERIA_HF_TOKEN=
# Public base URL workers use to reach the control-plane model mirrors (/hf/*
# and /v2/*). Set to your public domain, e.g. https://inferiallm.example.com
# (NO trailing slash, NO /gw). Leave blank to have workers download directly
# from upstream HuggingFace / OCI registries instead.
INFERIA_MODEL_MIRROR_BASE=
